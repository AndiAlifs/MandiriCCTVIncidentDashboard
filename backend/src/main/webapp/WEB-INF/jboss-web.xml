<?xml version="1.0" encoding="UTF-8"?>
<jboss-web xmlns="http://www.jboss.com/xml/ns/javaee"
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xsi:schemaLocation="http://www.jboss.com/xml/ns/javaee
             http://www.jboss.org/j2ee/schema/jboss-web_5_1.xsd">

  <context-root>/mandiri-cctv</context-root>

  <!-- Map the app's JNDI reference name to the server-side datasource -->
  <resource-ref>
    <res-ref-name>jdbc/MandiriCCTVDS</res-ref-name>
    <jndi-name>java:jboss/datasources/MandiriCCTVDS</jndi-name>
  </resource-ref>

</jboss-web>
